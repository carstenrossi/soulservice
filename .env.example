# Soulservice – Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.

# --- Database ---
POSTGRES_PASSWORD=changeme_generate_a_real_password
# Restricted runtime connection (non-owner role, subject to RLS).
# Leave empty for local dev (the app falls back to the soulservice_app dev role
# bootstrapped by infra/init.sql). Set explicitly in production.
APP_DATABASE_URL=

# --- Encryption ---
# Generate with: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
SOULSERVICE_MASTER_KEY=

# --- Embeddings (Phase 2) ---
MISTRAL_API_KEY=

# --- Chat Interface ---
ANTHROPIC_API_KEY=
CHAT_MCP_TOKEN=

# --- MCP Server ---
SOULSERVICE_HOST=0.0.0.0
SOULSERVICE_PORT=8000
SOULSERVICE_LOG_LEVEL=info

# --- Web UI (Phase 3, localhost-only) ---
WEB_HOST=127.0.0.1
WEB_PORT=8000
WEB_BASE_URL=http://localhost:6002
# REQUIRED: the admin UI refuses to start without this. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
WEB_SESSION_SECRET=
# Allowlist. Each entry is "email" (role defaults to admin) or "email:role"
# with role in viewer (read-only), editor (write knowledge), admin (+ tokens).
# Example: alice@example.com:admin,bob@example.com:viewer
WEB_ADMIN_EMAILS=
WEB_MAGIC_LINK_TTL_MINUTES=10
# Send session cookies only over HTTPS. Keep false for localhost/http,
# set true behind TLS in production.
WEB_SECURE_COOKIES=false
# Magic-link requests allowed per (client IP + email) per hour.
WEB_LOGIN_RATE_PER_HOUR=10
SMTP_HOST=localhost
SMTP_PORT=1025
WEB_FROM_EMAIL=soulservice@localhost
